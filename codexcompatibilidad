/* ----------------------------------------------------------
   LÓGICA
---------------------------------------------------------- */
const key = (a,b)=> a<=b ? a+"-"+b : b+"-"+a;
const dist = (a,b)=>{const d=Math.abs(a-b);return Math.min(d,12-d);};

function tierOf(s){
  if(s>=82) return {label:"Armonía",    col:"var(--jade)",    hex:"#6fa893"};
  if(s>=66) return {label:"Magnetismo", col:"var(--gold)",    hex:"#c9a24b"};
  if(s>=58) return {label:"Contraste",  col:"var(--amethyst)",hex:"#9b7fb8"};
  return         {label:"Desafío",     col:"var(--rust)",    hex:"#c2674a"};
}
function elementRelation(a,b){
  const A=SIGNS[a].el, B=SIGNS[b].el;
  if(A===B) return "Elementos gemelos";
  const comp = (x,y)=>(["Fuego","Aire"].includes(x)&&["Fuego","Aire"].includes(y))||(["Tierra","Agua"].includes(x)&&["Tierra","Agua"].includes(y));
  return comp(A,B) ? "Elementos cómplices" : "Elementos rivales";
}

let A=0, B=6; // Aries × Libra por defecto

function drawWheel(){
  const cx=160, cy=160, rGlyph=124, rNode=150;
  const ns="http://www.w3.org/2000/svg";
  const svg=document.getElementById("wheel");
  svg.innerHTML="";
  const t=tierOf(R[key(A,B)].s);

  const ring=(r,stroke,w,dash)=>{
    const c=document.createElementNS(ns,"circle");
    c.setAttribute("cx",cx);c.setAttribute("cy",cy);c.setAttribute("r",r);
    c.setAttribute("fill","none");c.setAttribute("stroke",stroke);c.setAttribute("stroke-width",w);
    if(dash)c.setAttribute("stroke-dasharray",dash);
    svg.appendChild(c);
  };
  ring(150,"#2b3447",1);
  ring(112,"#202838",1,"2 5");

  const pos=i=>{const ang=(-90+i*30)*Math.PI/180;return {x:cx+rGlyph*Math.cos(ang),y:cy+rGlyph*Math.sin(ang)};};

  const pa=pos(A), pb=pos(B);
  if(A!==B){
    const halo=document.createElementNS(ns,"line");
    halo.setAttribute("x1",pa.x);halo.setAttribute("y1",pa.y);
    halo.setAttribute("x2",pb.x);halo.setAttribute("y2",pb.y);
    halo.setAttribute("stroke",t.hex);halo.setAttribute("stroke-width","7");
    halo.setAttribute("stroke-linecap","round");halo.setAttribute("opacity",".18");
    svg.appendChild(halo);
    const line=document.createElementNS(ns,"line");
    line.setAttribute("x1",pa.x);line.setAttribute("y1",pa.y);
    line.setAttribute("x2",pb.x);line.setAttribute("y2",pb.y);
    line.setAttribute("stroke",t.hex);line.setAttribute("stroke-width","1.6");
    line.setAttribute("stroke-linecap","round");
    svg.appendChild(line);
  } else {
    const c=document.createElementNS(ns,"circle");
    c.setAttribute("cx",pa.x);c.setAttribute("cy",pa.y);c.setAttribute("r",10);
    c.setAttribute("fill","none");c.setAttribute("stroke",t.hex);c.setAttribute("stroke-width","1.6");
    svg.appendChild(c);
  }

  SIGNS.forEach((s,i)=>{
    const p=pos(i);
    const on = (i===A||i===B);
    const txt=document.createElementNS(ns,"text");
    txt.setAttribute("x",p.x);txt.setAttribute("y",p.y);
    txt.setAttribute("text-anchor","middle");txt.setAttribute("dominant-baseline","central");
    txt.setAttribute("font-size", on?22:16);
    txt.setAttribute("fill", on?t.hex:"#5a6377");
    txt.setAttribute("font-family","Fraunces, serif");
    txt.textContent=s.g;
    svg.appendChild(txt);
  });

  const deg=dist(A,B)*30;
  const big=document.createElementNS(ns,"text");
  big.setAttribute("x",cx);big.setAttribute("y",cy-6);
  big.setAttribute("text-anchor","middle");
  big.setAttribute("font-family","Fraunces, serif");
  big.setAttribute("font-size","40");big.setAttribute("fill","var(--parch)");
  big.textContent=deg+"°";
  svg.appendChild(big);
  const asp=document.createElementNS(ns,"text");
  asp.setAttribute("x",cx);asp.setAttribute("y",cy+18);
  asp.setAttribute("text-anchor","middle");
  asp.setAttribute("font-family","IBM Plex Mono, monospace");
  asp.setAttribute("font-size","10");asp.setAttribute("letter-spacing","2");
  asp.setAttribute("fill","var(--gold)");
  asp.textContent=ASPECTS[dist(A,B)].toUpperCase();
  svg.appendChild(asp);
}

function render(){
  const r=R[key(A,B)], sa=SIGNS[A], sb=SIGNS[B], t=tierOf(r.s);

  document.getElementById("nameA").textContent=sa.n;
  document.getElementById("nameB").textContent=sb.n;

  document.getElementById("title").innerHTML =
    `${sa.n}<span class="x">×</span>${sb.n}`;

  const modRel = sa.mo===sb.mo ? "Modalidades gemelas" : "Modalidades distintas";
  document.getElementById("meta").innerHTML = [
    `<span class="chip">${sa.g} <b>${sa.el}</b> · ${sa.pl}</span>`,
    `<span class="chip">${sb.g} <b>${sb.el}</b> · ${sb.pl}</span>`,
    `<span class="chip"><b>${ASPECTS[dist(A,B)]}</b> · ${dist(A,B)*30}°</span>`,
    `<span class="chip">${elementRelation(A,B)}</span>`,
    `<span class="chip">${modRel}</span>`,
  ].join("");

  document.getElementById("scoreNum").textContent=r.s;
  document.getElementById("scoreNum").style.color=t.col;
  const tw=document.getElementById("tier");
  tw.textContent="— "+t.label; tw.style.color=t.col;

  const fill=document.getElementById("barFill");
  fill.style.width=r.s+"%"; fill.style.background=t.col;

  document.getElementById("forces").textContent=r.f;
  document.getElementById("tensions").textContent=r.t;
  document.getElementById("verdict").textContent="« "+r.v+" »";

  document.querySelectorAll('.picker[data-slot="a"] .glyph').forEach((b,i)=>b.classList.toggle("sel",i===A));
  document.querySelectorAll('.picker[data-slot="b"] .glyph').forEach((b,i)=>b.classList.toggle("sel",i===B));
  document.querySelectorAll('td.cell').forEach(c=>{
    c.classList.toggle("active", c.dataset.k===key(A,B));
  });

  drawWheel();
}

function buildRail(id, slot){
  const rail=document.getElementById(id);
  SIGNS.forEach((s,i)=>{
    const b=document.createElement("button");
    b.className="glyph"; b.type="button";
    b.innerHTML=`${s.g}<small>${s.n.slice(0,3).toUpperCase()}</small>`;
    b.setAttribute("aria-label",s.n);
    b.addEventListener("click",()=>{ if(slot==="a")A=i; else B=i; render(); });
    rail.appendChild(b);
  });
}

function buildMatrix(){
  const thead=document.querySelector("#matrix thead");
  const tbody=document.querySelector("#matrix tbody");
  let h="<tr><th></th>";
  SIGNS.forEach(s=>h+=`<th title="${s.n}">${s.g}</th>`);
  h+="</tr>"; thead.innerHTML=h;

  let body="";
  SIGNS.forEach((rs,i)=>{
    body+=`<tr><th class="rowh" title="${rs.n}">${rs.g}</th>`;
    SIGNS.forEach((cs,j)=>{
      const r=R[key(i,j)], t=tierOf(r.s);
      body+=`<td class="cell" data-i="${i}" data-j="${j}" data-k="${key(i,j)}"
              style="background:${t.hex};color:${r.s>=66?'#0d1018':'#f3eede'}"
              title="${rs.n} × ${cs.n} — ${r.s}/100">${r.s}</td>`;
    });
    body+="</tr>";
  });
  tbody.innerHTML=body;

  tbody.querySelectorAll("td.cell").forEach(c=>{
    c.addEventListener("click",()=>{
      A=+c.dataset.i; B=+c.dataset.j; render();
      document.querySelector(".reading").scrollIntoView({behavior:"smooth",block:"center"});
    });
  });
}

buildRail("railA","a");
buildRail("railB","b");
buildMatrix();
render();
</script>
