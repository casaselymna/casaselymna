function buildRadarCard(t,top){
  const c=el("section","card");
  c.innerHTML=`<div class="radar-wrap">${radarSVG(t)}</div>
    <p class="radar-cap">${state.asc?`Mezcla Sol ${SIGNS[state.sign].glyph} + Ascendente ${SIGNS[state.asc].glyph} · `:"Su constelación — "}dominantes: ${top.map(x=>x.l.toLowerCase()).join(" · ")}</p>`;
  return c;
}

function radarSVG(t){
  const size=300, cx=size/2, cy=size/2+6, R=110;
  const n=RADAR.length;
  const pts=RADAR.map(([k,l],i)=>{
    const ang=-Math.PI/2 + i*2*Math.PI/n;
    const val=(t[k]??0)/100;
    return {ang,val,l,
      x:cx+Math.cos(ang)*R*val, y:cy+Math.sin(ang)*R*val,
      lx:cx+Math.cos(ang)*(R+24), ly:cy+Math.sin(ang)*(R+24)};
  });
  let rings="";
  [0.25,0.5,0.75,1].forEach(f=>{
    const ring=RADAR.map(([k],i)=>{
      const a=-Math.PI/2+i*2*Math.PI/n;
      return `${(cx+Math.cos(a)*R*f).toFixed(1)},${(cy+Math.sin(a)*R*f).toFixed(1)}`;
    }).join(" ");
    rings+=`<polygon points="${ring}" fill="none" stroke="rgba(236,230,216,.08)" stroke-width="1"/>`;
  });
  let spokes="";
  pts.forEach(p=>{spokes+=`<line x1="${cx}" y1="${cy}" x2="${(cx+Math.cos(p.ang)*R).toFixed(1)}" y2="${(cy+Math.sin(p.ang)*R).toFixed(1)}" stroke="rgba(236,230,216,.06)"/>`;});
  const poly=pts.map(p=>`${p.x.toFixed(1)},${p.y.toFixed(1)}`).join(" ");
  let dots="",labels="";
  pts.forEach(p=>{
    dots+=`<circle cx="${p.x.toFixed(1)}" cy="${p.y.toFixed(1)}" r="3.2" fill="#e6c884"/>`;
    const anchor = Math.abs(Math.cos(p.ang))<0.3 ? "middle" : (Math.cos(p.ang)>0?"start":"end");
    labels+=`<text x="${p.lx.toFixed(1)}" y="${(p.ly+4).toFixed(1)}" fill="#8b91a8" font-size="11" font-family="Inter,sans-serif" text-anchor="${anchor}">${p.l}</text>`;
  });
  return `<svg viewBox="-62 -6 ${size+124} ${size+22}" width="100%" style="max-width:380px" role="img" aria-label="Perfil de personalidad en radar">
    ${rings}${spokes}
    <polygon points="${poly}" fill="rgba(211,173,87,.16)" stroke="#d3ad57" stroke-width="1.5"/>
    ${dots}${labels}
  </svg>`;
}

function reset(){
  state.step=0;state.sex=null;state.sign=null;state.asc=null;state.obs=new Set();state.goal=null;state.ctx=null;
  $("#result").style.display="none";
  $("#form").style.display="block";
  $("#steps").style.display="flex";
  $("#obsCount").textContent="0 marcado";
  renderSex();renderSigns();renderAsc();renderObs();renderGoal();showStep();
}

renderSex();renderSigns();renderAsc();renderObs();renderGoal();showStep();
</script>
</body>
</html>


