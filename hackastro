  .tagline{font-family:"Fraunces",serif;font-style:italic;font-size:clamp(17px,3.4vw,22px);color:var(--gold-soft);margin:2px 0 0;letter-spacing:.01em}
  .lede{color:var(--muted);font-size:16px;max-width:54ch;margin:0 auto}
  header.hero{text-align:center;margin:14px 0 34px}

  .steps{display:flex;gap:8px;justify-content:center;margin:0 0 26px;flex-wrap:wrap}
  .pip{display:flex;align-items:center;gap:8px;font-size:12px;color:var(--muted-2);letter-spacing:.04em}
