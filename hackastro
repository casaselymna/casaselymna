  .asc-h{font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:var(--peri-soft);font-weight:600;margin:24px 0 10px}
  .asc-none .glyph{color:var(--muted-2)}
  .shuffle-op{margin-top:12px;font-size:13.5px;padding:11px 16px;min-height:42px}
</style>
</head>
