  .signs{display:grid;grid-template-columns:repeat(auto-fit,minmax(118px,1fr));gap:10px}
  .sign{cursor:pointer;background:var(--surface-2);border:1px solid var(--line-soft);color:var(--ink);border-radius:11px;padding:13px 12px;text-align:center;transition:.18s}
