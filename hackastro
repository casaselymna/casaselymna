  @media (prefers-reduced-motion:reduce){.reveal{animation:none}}
  @media (max-width:400px){
    .card{padding:22px 16px}
    ol.copylist li{padding-left:40px;flex-wrap:wrap}
    ol.copylist li .ct{min-width:60%}
    .copy{margin-left:auto}
  }
