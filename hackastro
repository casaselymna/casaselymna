function block(title,ix,html){
  const c=el("section","card block");
  c.innerHTML=`<h3 class="b-title"><span class="ix">${ix}</span>${title}</h3>${html}`;
  return c;
}
function listBlock(title,ix,items,avoid){
  const ul=`<ul class="list${avoid?" avoid":""}">${items.map(i=>`<li>${genderize(capitalize(i))}</li>`).join("")}</ul>`;
  return block(title,ix,ul);
