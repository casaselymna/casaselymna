  .opt{appearance:none;cursor:pointer;text-align:left;background:var(--surface-2);border:1px solid var(--line-soft);color:var(--ink);border-radius:11px;padding:14px 16px;font:inherit;transition:.18s;display:flex;flex-direction:column;gap:2px}
