  ol.copylist li{display:flex;align-items:center;gap:10px;justify-content:space-between}
  ol.copylist li .ct{flex:1}
  .copy{flex:none;cursor:pointer;font:inherit;font-size:13px;font-weight:600;letter-spacing:.02em;color:var(--gold-soft);background:rgba(211,173,87,.06);border:1px solid var(--line);border-radius:9px;padding:9px 14px;min-height:40px;transition:.15s;white-space:nowrap}
