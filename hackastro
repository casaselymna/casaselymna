  ul.list.avoid li::before{background:var(--bad)}
  ol.lines{margin:0;padding:0;list-style:none;counter-reset:l;display:flex;flex-direction:column;gap:10px}
  ol.lines li{counter-increment:l;position:relative;padding:12px 14px 12px 46px;background:var(--surface-2);border:1px solid var(--line-soft);border-radius:10px;font-size:14.5px}
  ol.lines li::before{content:counter(l,decimal-leading-zero);position:absolute;left:14px;top:12px;font-size:12px;color:var(--gold);font-weight:600;letter-spacing:.05em}

