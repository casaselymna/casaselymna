  .radar-wrap{display:flex;justify-content:center;margin:0 0 6px}
  .radar-cap{text-align:center;color:var(--muted-2);font-size:12px;letter-spacing:.04em;margin-bottom:14px}

  .footer-note{text-align:center;color:var(--muted-2);font-size:12.5px;margin-top:30px;padding-top:20px;border-top:1px solid var(--line-soft)}
  .restart{display:block;margin:26px auto 0}
  .reveal{animation:rise .5s cubic-bezier(.2,.7,.2,1) both}
