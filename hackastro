  .btn.ghost{background:transparent;border-color:var(--line-soft);color:var(--muted)}
  .btn.ghost:hover{color:var(--ink);border-color:var(--line)}

  #result{display:none}
  .res-head{text-align:center;margin:0 0 24px}
  .res-glyph{font-family:"Fraunces",serif;font-size:46px;color:var(--gold-soft);line-height:1}
  .res-name{font-family:"Fraunces",serif;font-size:27px;font-weight:600;margin:6px 0 2px}
  .res-meta{font-size:12.5px;color:var(--muted-2);letter-spacing:.06em;text-transform:uppercase}

