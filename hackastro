function showStep(){
  document.querySelectorAll(".step").forEach(s=>{ s.hidden = +s.dataset.step !== state.step; });
  if(state.step===2) renderObs();
  $("#prevBtn").style.visibility = state.step===0 ? "hidden":"visible";
  $("#nextBtn").textContent = state.step===3 ? "Generar mi estrategia" : "Continuar";
  renderSteps();updateNav();
  window.scrollTo({top:0,behavior:"smooth"});
}
function canProceed(){
  if(state.step===0) return !!state.sex;
  if(state.step===1) return !!state.sign;
  if(state.step===2) return true;
  if(state.step===3) return !!state.goal && !!state.ctx;
  return false;
}
function updateNav(){ $("#nextBtn").disabled = !canProceed(); }

$("#prevBtn").onclick=()=>{ if(state.step>0){state.step--;showStep();} };
$("#nextBtn").onclick=()=>{
  if(!canProceed())return;
  if(state.step<3){state.step++;showStep();}
  else generate();
};

/* ============================================================
   MOTOR
   ============================================================ */
function computeTraits(){
  const sign=SIGNS[state.sign];
  const asc=state.asc?SIGNS[state.asc]:null;
  const t={};AXES.forEach(a=>{
    const sun=sign.traits[a]??45;
    t[a]=asc?Math.round(sun*0.7+(asc.traits[a]??45)*0.3):sun;
  });
  state.obs.forEach(id=>{
    const it=OBS_GROUPS.flatMap(g=>g.items).find(o=>o.id===id);
    if(!it)return;
    for(const k in it.d){ if(k in t) t[k]=Math.max(0,Math.min(100, t[k]+it.d[k])); }
  });
  return t;
}
function topTraits(t,n=3){
  return RADAR.map(([k,l])=>({k,l,v:t[k]??0})).sort((a,b)=>b.v-a.v).slice(0,n);
}
function pronom(){ return SEX.find(s=>s.id===state.sex).pr; }

/* Concordancia de género: {masculino|femenino} */
function genderize(s){
  if(s==null) return s;
  const sex=SEX.find(x=>x.id===state.sex);
  const fem= sex ? sex.pr.g==="f" : false;
  return String(s).replace(/\{([^{}|]*)\|([^{}|]*)\}/g,(m,a,b)=> fem? b : a);
}

function shuffle(a){a=a.slice();for(let i=a.length-1;i>0;i--){const j=Math.floor(Math.random()*(i+1));[a[i],a[j]]=[a[j],a[i]];}return a;}
function pickOpeners(sign,t){
  const ctx=state.ctx, tons=sign.tons;
  const question=sign.questions[0];
  const fill = s => s.replace("{question}",question);
  const scoreTon=o=>o.tons.filter(x=>tons.includes(x)).length;
  // mezcla + orden estable por afinidad de tono => variedad en cada generación
  let pool=shuffle(OPENERS.filter(o=>o.ctx===ctx));
  pool.sort((a,b)=>scoreTon(b)-scoreTon(a));
  let out=pool.map(o=>fill(o.txt));
  if(state.goal==="cafe" && !out.some(x=>/café/i.test(x))){
    out.unshift("¿Y si seguimos esta plática con un café esta semana?");
  }
  return out.slice(0, Math.min(6, out.length));
}

function traitPhrase(top){
  const map={
    sensibilite:"una sensibilidad que se nota rápido",
    sociabilite:"una soltura social evidente",
    energie:"una energía que se nota",
    intellect:"una mente que va rápido",
    romantisme:"un fondo romántico que no esconde",
    aventure:"unas ganas claras de aventura",
    mystere:"un aire de misterio que intriga",
    confiance:"una seguridad tranquila",
    creativite:"una vena creativa",
    independance:"una independencia real",
  };
  return top.map(x=>map[x.k]).filter(Boolean);
}

function generate(){
  const sign=SIGNS[state.sign];
  const asc=state.asc?SIGNS[state.asc]:null;
  const t=computeTraits();
  const pr=pronom();
  const top=topTraits(t,3);

  const obsLabels=[...state.obs].map(id=>{
    const it=OBS_GROUPS.flatMap(g=>g.items).find(o=>o.id===id);return it?it.label.toLowerCase():null;
  }).filter(Boolean);

  // === Lectura detallada (el signo es la guía) ===
  const sig4 = sign.signatures.slice(0,4).map(s=>s.charAt(0).toLowerCase()+s.slice(1)).join(" ; ");
  const touche = sign.estSeduit.replace(/^Por\s+/i,"");
  const top4 = traitPhrase(topTraits(t,4));
  const lowerFirst = s => s.charAt(0).toLowerCase()+s.slice(1);
  const paras=[];
  paras.push(sign.personnalite);
  if(asc){
    const asc2=asc.signatures.slice(0,2).map(x=>x.charAt(0).toLowerCase()+x.slice(1)).join(" ; ");
    paras.push(`A primera vista, por su ascendente en ${asc.nom}, proyecta otra capa: ${asc2}. Es lo que muestra antes de abrirse de verdad.`);
  }
  paras.push(`Lo que más ${pr.obj} define: ${sig4}.`);
  paras.push(`En el fondo, ${pr.suj} valora: ${sign.valeurs.join(", ")}. Y lo que ${pr.obj} hace huir: ${sign.peurs.join(", ")}.`);
  if(top4.length) paras.push(`Al observar, lo que más resalta en ${pr.suj}: ${top4.join(", ")}.`);
  paras.push(`Lo que más ${pr.obj} conquista: ${lowerFirst(touche)}`);
  paras.push(`Su forma de comunicarse: ${lowerFirst(sign.communication)}`);
  if(obsLabels.length){
    paras.push(`Tus observaciones (${obsLabels.slice(0,6).join(", ")}) ${obsLabels.length>=3?"encajan con el perfil y lo vuelven aún más preciso":"agregan un matiz útil al retrato"}.`);
  }
  const readingHTML = paras.map(x=>`<p class="prose" style="margin:0 0 10px">${x}</p>`).join("");

  const openers=pickOpeners(sign,t);
  const compliments=sign.compliments.slice(0,10);
  const questions=[...sign.questions,
    `¿Qué vas a hacer el fin?`,
    `¿Cuál es tu película favorita?`,
    `¿Te gusta bailar?`,
    `¿Qué te pone de buenas?`,
    `Si pudieras irte a cualquier lado mañana, ¿a dónde irías?`
  ].slice(0,10);

  const goalLab=GOALS[state.goal].lab.toLowerCase();
  const ctxLab=CONTEXTS[state.ctx].lab;

  const closer = {
    glace:"Sigue tranquilo, disfruta el momento. No hay que correr.",
    discussion:"Propón seguir luego: «¿Seguimos esta plática un día, con algo de tomar?»",
    envie:"Cierra en buena nota: «Me encantó platicar contigo, hay que repetir.» Y deja con ganas de más.",
    cafe:"Propón el café claro: «¿Te late que tomemos un café esta semana?» Da un día.",
    seduire:"Pide su número con una sonrisa: «Dame tu número, me dieron ganas de volver a verte.»"
  }[state.goal];
  const interestSignals = `¿${pr.suj==="él"?"Él":"Ella"} te responde con una sonrisa, te hace preguntas, busca tu mirada o se queda cerca de ti? Buena señal. Avanza, pero tranquilo.`;

  // === DOM ===
  const r=$("#result");r.innerHTML="";r.className="reveal";

  r.appendChild(buildHead(sign));
  r.appendChild(buildRadarCard(t,top));

  r.appendChild(block("La lectura","Perfil",
    `<p class="prose muted" style="margin:0 0 12px">${pr.obj==="lo"?"Lo":"La"} observé por ti — esto es lo que leo:</p>${genderize(readingHTML)}`));

  r.appendChild(listBlock("Rasgos distintivos del signo","Rasgos", sign.signatures, false));

  r.appendChild(listBlock("Lo que probablemente le gusta","Afinidades", sign.attire, false));
  r.appendChild(listBlock("Lo que mejor evitar","Errores", sign.eviter, true));

  r.appendChild(block("Cómo llamar su atención","Estrategia",
    `<p class="prose">${genderize(capitalize(sign.seduit))} ${sign.estSeduit?` ${genderize(capitalize(sign.estSeduit))}`:""}</p>
     <p class="prose muted" style="margin-top:8px">Tu intención: <strong>${goalLab}</strong>, contexto <strong>${ctxLab}</strong>. Mantén un ritmo que respete su tempo — ${genderize(lowerFirst(sign.communication))}</p>`));

  r.appendChild(listBlock("Lo que va a notar en ti","Señales", sign.remarque, false));

  r.appendChild(block("Cumplidos a su medida","Cumplidos",
    `<ol class="lines copylist">${compliments.map(copyLi).join("")}</ol>`));

  const opCard=block("Frases para romper el hielo","Acercamiento",
    `<ol class="lines copylist" id="openerList"></ol><button type="button" class="btn ghost shuffle-op" id="shuffleOp">↻ Ver otras frases</button>`);
  r.appendChild(opCard);

  r.appendChild(numBlock("Preguntas para que platique","Conversación", questions));

  r.appendChild(block(`${pr.suj==="él"?"Si él":"Si ella"} parece interesad${pr.g==="x"?"":pr.obj==="la"?"a":"o"}`,"Impulso",
    `<p class="prose">${interestSignals}</p>
     <ul class="list" style="margin-top:12px">
       <li>Quédate relajado, ya vas bien. No hace falta exagerar.</li>
       <li>Retoma lo que ${pr.suj} dice, demuestra que sí escuchas.</li>
       <li>Echa un cumplido sincero, uno solo, pero que pegue.</li>
       <li>Deja algo de misterio, que le queden ganas de saber más.</li>
       <li>Si fluye, propón un momento juntos antes de que se enfríe.</li>
     </ul>
     <p class="prose" style="margin-top:12px"><strong>El siguiente paso:</strong> ${closer}</p>`));

  r.appendChild(block(`${pr.suj==="él"?"Si él":"Si ella"} se muestra distante`,"Salida",
    `<p class="prose">¿Respuestas cortas, mirada en otro lado, poco entusiasmo? Es un no, y está bien. Retírate con una sonrisa: <em>«Estuvo padre platicar contigo, te dejo, ¡bonita noche!»</em> Quedas con clase y dejas la puerta abierta para después.</p>`));

  const again=el("button","btn ghost restart","Empezar otra lectura");
  again.type="button";again.onclick=reset;
  r.appendChild(again);

  $("#form").style.display="none";
  $("#steps").style.display="none";
  r.style.display="block";

  CURRENT={sign,t,ctx:state.ctx};
  renderOpeners(sign,t,state.ctx);
  window.scrollTo({top:0,behavior:"smooth"});
}

/* ---- copiar ---- */
function copyLi(text){
  const g=genderize(text);
  const esc=g.replace(/&/g,"&amp;").replace(/"/g,"&quot;").replace(/</g,"&lt;");
  return `<li><span class="ct">${g}</span><button type="button" class="copy" data-txt="${esc}">Copiar</button></li>`;
}
document.addEventListener("click", e=>{
  const b=e.target.closest && e.target.closest(".copy"); if(!b) return;
  const txt=b.getAttribute("data-txt");
  const done=()=>{const old=b.textContent;b.textContent="¡Copiado!";b.classList.add("ok");setTimeout(()=>{b.textContent=old;b.classList.remove("ok");},1200);};
  if(navigator.clipboard&&navigator.clipboard.writeText){navigator.clipboard.writeText(txt).then(done).catch(()=>fallbackCopy(txt,done));}
  else fallbackCopy(txt,done);
});
document.addEventListener("click", e=>{
  const b=e.target.closest && e.target.closest("#shuffleOp"); if(!b||!CURRENT) return;
  renderOpeners(CURRENT.sign,CURRENT.t,CURRENT.ctx);
});
function fallbackCopy(txt,cb){const ta=document.createElement("textarea");ta.value=txt;ta.style.position="fixed";ta.style.opacity="0";document.body.appendChild(ta);ta.focus();ta.select();try{document.execCommand("copy");}catch(e){}document.body.removeChild(ta);cb&&cb();}

function renderOpeners(sign,t,ctx){
  state.ctx=ctx;
  const list=$("#openerList");if(!list)return;
  list.innerHTML=pickOpeners(sign,t).map(copyLi).join("");
}

/* ---- helpers DOM ---- */
function capitalize(s){return s.charAt(0).toUpperCase()+s.slice(1);}
function buildHead(sign){
  const h=el("div","res-head");
  const asc=state.asc?SIGNS[state.asc]:null;
  const ascHtml=asc?` · Asc ${asc.glyph} ${asc.nom}`:"";
